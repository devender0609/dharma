# Copy this file to .env.local and fill in your values
# Never commit .env.local to Git

# Optional: OpenAI / Anthropic API key for real AI responses
VITE_AI_API_KEY=your_api_key_here

# Optional: Panchang API (e.g. Drik Panchang)
VITE_PANCHANG_API_KEY=your_panchang_api_key

# Optional: Firebase (for user auth + habit sync)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# App URL (set this in Vercel dashboard too)
VITE_APP_URL=https://your-app.vercel.app

# Stripe hosted billing links
VITE_STRIPE_PAYMENT_LINK_MONTHLY=
VITE_STRIPE_PAYMENT_LINK_YEARLY=
VITE_STRIPE_CUSTOMER_PORTAL_URL=
VITE_BILLING_SUPPORT_EMAIL=billing@vedanta.ai
